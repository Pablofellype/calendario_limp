rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmployee() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider == 'custom';
    }

    function isAdmin() {
      return isSignedIn() && !isEmployee();
    }

    function isSelf(userId) {
      return isEmployee() && request.auth.uid == userId;
    }

    function isAssigned(taskData) {
      return taskData.assigneeIds is list && taskData.assigneeIds.hasAny([request.auth.uid]);
    }

    match /users/{userId} {
      allow read: if isAdmin() || isSelf(userId);

      allow create, delete: if isAdmin();

      allow update: if isAdmin() || (
        isSelf(userId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'webPushSubs',
          'webPushUpdatedAt',
          'fcmTokens',
          'fcmUpdatedAt'
        ])
      );
    }

    match /cleaning_tasks/{y}/{m}/{d}/atividades/{taskId} {
      allow read: if isSignedIn();

      allow create, delete: if isAdmin();

      allow update: if isAdmin() || (
        isEmployee() &&
        isAssigned(resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'completed',
          'completedBy',
          'comments',
          'photos',
          'hasPhotoProof'
        ]) &&
        request.resource.data.assignee == resource.data.assignee &&
        request.resource.data.assigneeIds == resource.data.assigneeIds &&
        request.resource.data.title == resource.data.title &&
        request.resource.data.date == resource.data.date &&
        request.resource.data.order == resource.data.order &&
        request.resource.data.recurrence == resource.data.recurrence &&
        request.resource.data.groupId == resource.data.groupId &&
        request.resource.data.searchKeywords == resource.data.searchKeywords &&
        request.resource.data.completed is bool &&
        (request.resource.data.completedBy is string || request.resource.data.completedBy == null) &&
        request.resource.data.comments is list &&
        request.resource.data.photos is list
      );
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}