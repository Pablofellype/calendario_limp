# Frontend (Vite)
VITE_FCM_VAPID_KEY=
VITE_WEBPUSH_PUBLIC_KEY=

# Backend APIs (/api/*)
# Use raw JSON or base64 JSON from Firebase service account.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional allowlist for /api/notify (comma-separated)
ADMIN_EMAILS=

# Web Push (for /api/notify)
WEBPUSH_PUBLIC_KEY=
WEBPUSH_PRIVATE_KEY=
WEBPUSH_SUBJECT=mailto:admin@example.com

